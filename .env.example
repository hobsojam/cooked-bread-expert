# Public app URL used in generated links.
APP_BASE_URL=http://localhost:3000

# Demo mode enables warnings, watermarks, short retention, and noindex behavior.
DEMO_MODE=true

# Public demo sessions expire after 6 hours by default.
DEMO_SESSION_RETENTION_HOURS=6

# Self-hosted operators can set their own retention period.
SESSION_RETENTION_HOURS=168

# Export behavior. Demo exports should be clearly watermarked.
ENABLE_EXPORTS=true
DEMO_WATERMARK_TEXT=DEMO - DO NOT USE WITH REAL PERSONAL DATA

# Database connection string. Use a real value only in local .env files or deployment secrets.
DATABASE_URL=postgres://example_user:example_password@localhost:5432/cooked_bread_expert

# Optional cleanup behavior.
DELETE_EXPIRED_SESSIONS_ON_STARTUP=true
